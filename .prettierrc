{
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "semi": true,
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "bracketSameLine": false,
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "react-native",
    "^expo(.*)",
    "^@expo(.*)",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@sportspay/shared(.*)",
    "",
    "^[./]",
    "",
    "<TYPES>"
  ],
  "importOrderTypeScriptVersion": "5.6.3"
}
